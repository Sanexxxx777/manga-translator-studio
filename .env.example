# Copy to .env and fill in your values.

# Google AI Studio key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_key_here

# Gemini model. 2.5-flash is faster/cheaper and reads conversational tone better
# than 2.5-pro for manga dialogue, so flash is the default.
GEMINI_MODEL=gemini-2.5-flash

# Target language. Codes from manga-image-translator: RUS, ENG, CHS, JPN, KOR, ESP, FRA, ...
TARGET_LANG=RUS

# Remote machine running Cloudflare WARP in proxy mode (warp-cli mode proxy → port 40000).
# Required if Gemini is geo-blocked from your network or if a local VPN/proxy
# client is interfering with MangaDex CDN. See README → "Setting up the WARP host".
WARP_SSH_HOST=user@your-remote-host
# WARP_SSH_PORT=22
# WARP_LOCAL_PORT=1085
# WARP_REMOTE_PORT=40000
